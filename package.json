{
  "name": "mac-local-rtmp-server",
  "productName": "Local RTMP Server",
  "version": "3.0",
  "description": "Local RTMP streaming server for macOS (Apple Silicon / ARM64)",
  "main": "main.js",
  "build": {
    "appId": "com.localrtmp.server",
    "mac": {
      "category": "public.app-category.video"
    }
  },
  "dependencies": {
    "electron-context-menu": "^3.6.1",
    "filesize": "^10.1.0",
    "get-port": "^5.1.1",
    "hls.js": "^1.6.16",
    "lodash": "^4.17.21",
    "menubar": "^9.3.0",
    "node-media-server": "^2.6.2",
    "shortid": "^2.2.8"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "patch-package": "^8.0.1"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64",
    "postinstall": "patch-package",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zpqnzpqn/macos-RTMP-Server.git"
  },
  "keywords": [
    "rtmp",
    "server",
    "streaming",
    "media",
    "mac",
    "electron",
    "apple-silicon",
    "arm64",
    "macos",
    "menubar",
    "stream",
    "live-streaming",
    "rtmp-server"
  ],
  "author": "zpqnzpqn",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zpqnzpqn/macos-RTMP-Server/issues"
  },
  "homepage": "https://github.com/zpqnzpqn/macos-RTMP-Server#readme"
}
